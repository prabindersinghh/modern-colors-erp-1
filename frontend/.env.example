# Same-origin API path — the Vite dev server proxies /api to the backend.
# Leave as "/api" for local dev (and phone testing over HTTPS). Set to a full
# URL only if the API is hosted on a different origin in production.
VITE_API_URL="/api"

# Phone camera testing: serve the dev server over HTTPS so getUserMedia works
# from another device on the LAN:  VITE_HTTPS=true npm run dev
