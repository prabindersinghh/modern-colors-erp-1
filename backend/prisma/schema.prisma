// Modern Colours — Phase 1 data model.
// Source of truth: docs/ARCHITECTURE.md §6. Update BOTH together on any change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations use a DIRECT (non-pooled) connection — Prisma migrate needs advisory
  // locks that Neon's PgBouncer pooler does not support (they hang). Runtime queries
  // still use the pooled DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Enums ─────────────────────────

enum Role {
  ADMIN // Phase 1 full access; in Phase 2 this login is the "Store" (label only)
  SUPERVISOR
  OPERATOR
  OVERSIGHT // Phase 2 — factory-wide VIEW-ONLY "Admin" (no actions)
  PRODUCTION_HEAD // Phase 2 — PU/Enamel/Powder head, scoped by `department`
  DISPATCH // Phase 3 — finished-goods dispatch ONLY (no raw stock, no requests)
  REVIEWER // Segregation of duties — VIEW-ONLY: invoice document + digital slip, nothing else
}

// Phase 2 — production departments. A PRODUCTION_HEAD is scoped to exactly one.
enum Department {
  PU
  ENAMEL
  POWDER
}

// Phase 2 — request lifecycle. Used per-LINE (PENDING/APPROVED/PARTIAL/REJECTED) and for
// the parent request overall status (adds IN_PROGRESS when some lines are still pending).
enum RequestStatus {
  PENDING // awaiting Store
  IN_PROGRESS // PARENT ONLY — some lines actioned, some still pending
  APPROVED // line: full accept · parent: every line approved
  PARTIAL // line: lower approvedKg · parent: reviewed with a mixed outcome
  REJECTED // line: rejected with a reason · parent: every line rejected
}

// Phase 2 — stock movement type. Every unit scan offers all three (Override 3).
enum StockTxnType {
  ADD // material coming back INTO stock (from a department)
  DEDUCT // material going OUT (for a department)
  DISCARD // wasted/damaged, not tied to a department
}

// Phase 3 — batch lifecycle. A batch is the thread from raw materials to finished goods.
enum BatchStatus {
  OPEN // created; materials being requested / issued against it
  OUTPUT_RECORDED // production output entered, awaiting the head's confirmation
  CONFIRMED // output confirmed — FG QR codes may now be generated
  CLOSED // FG generated/dispatched; further requests warn (never blocked)
}

// Phase 3 — per-drum finished-goods lifecycle.
enum FgStatus {
  GENERATED // QR minted, sticker printable
  READY // labelled / stored, awaiting dispatch
  DISPATCHED // scanned out by the Dispatch role
  SCRAPPED // returned and written off — permanently out of inventory
  REFURBISHED // returned and replaced by a NEW FG unit (see refurbishedFrom)
}

// PO-level lifecycle (the document). See ARCHITECTURE.md §6 status note.
enum POStatus {
  PO_UPLOADED // uploaded, extraction not yet run
  AI_EXTRACTED // Claude returned fields; pending review
  OPERATOR_VERIFIED // operator confirmed (hard gate passed)
  REGISTERED // materials + QR created
}

// How the PO data was produced.
enum POSource {
  AI // Claude extraction
  MANUAL // manual-entry fallback (I7)
}

// Per-physical-unit lifecycle (the tracked entity after registration).
enum MaterialStatus {
  REGISTERED
  ARRIVED
  SCANNED
  WEIGHED
  READY_FOR_PRODUCTION
}

// Catalogue match outcome for an extracted line (I6 — informational, never gates).
enum MatchType {
  EXACT
  SIMILAR
  NONE
}

// ───────────────────────── Users / Auth ─────────────────────────

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         Role        @default(OPERATOR)
  department   Department? // Phase 2 — set only for PRODUCTION_HEAD users
  active       Boolean     @default(true)
  lastLoginAt  DateTime? // set on every successful login (User Management display)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  uploadedPOs        PurchaseOrder[]     @relation("UploadedBy")
  confirmedPOs       PurchaseOrder[]     @relation("ConfirmedBy")
  weighedUnits       Material[]          @relation("WeighedBy")
  auditEntries       AuditLog[]          @relation("ActorAudit")
  settingsUpdates    Setting[]           @relation("SettingUpdatedBy")
  productionRequests ProductionRequest[] @relation("RequestedBy")
  reviewedRequests   ProductionRequest[] @relation("ReviewedBy")
  stockTransactions  StockTransaction[]  @relation("TxnActor")

  // Phase 3 — batches, production output, dispatch
  createdBatches   Batch[]               @relation("BatchCreatedBy")
  recordedOutputs  ProductionOutput[]    @relation("OutputRecordedBy")
  confirmedOutputs ProductionOutput[]    @relation("OutputConfirmedBy")
  dispatchedGoods  FinishedGood[]        @relation("FgDispatchedBy")
  returnedGoods    FinishedGood[]        @relation("FgReturnedBy")
  reprintRequested LabelReprintRequest[] @relation("ReprintRequestedBy")
  reprintDecided   LabelReprintRequest[] @relation("ReprintDecidedBy")
  slipsGenerated   ReceivingSlip[]       @relation("SlipGeneratedBy")
  flagsChanged     SystemFlag[]          @relation("FlagUpdatedBy")
  slipsFinalized   ReceivingSlip[]       @relation("SlipFinalizedBy")

  @@index([role])
}

// ───────────────────────── Master Catalogue ─────────────────────────

model MasterCatalogueItem {
  id                String   @id @default(uuid())
  materialName      String
  sku               String   @unique
  hsnCode           String? // HSN/SAC tax code — distinct from SKU (see FIELD_REFERENCE.md)
  category          String?
  unit              String?
  standardPackaging String?
  // Admin-set stock thresholds, in the material's OWN unit (kg or L). Drive the
  // stock-percentage display and low-stock alerts. NULL = not set (built-in defaults).
  minLevel          Float?
  maxLevel          Float?
  metadata          Json?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  matchedLineItems POLineItem[] @relation("MatchedCatalogue")

  @@index([materialName])
  @@index([sku])
}

// ───────────────────────── Purchase Orders ─────────────────────────

model PurchaseOrder {
  id            String    @id @default(uuid())
  poNumber      String?
  supplier      String?
  fileKey       String? // storage key (R2 / disk). Null only for pure manual entry.
  fileName      String?
  status        POStatus  @default(PO_UPLOADED)
  source        POSource  @default(AI)
  extractedJson Json? // raw Claude output for audit/debug
  deliveryDate  DateTime?

  uploadedById String
  uploadedBy   User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  confirmedById String?
  confirmedBy   User?     @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems       POLineItem[]
  materials       Material[]
  reprintRequests LabelReprintRequest[]
  receivingSlip   ReceivingSlip?

  @@index([poNumber])
  @@index([supplier])
  @@index([status])
  @@index([createdAt])
}

// Editable working set BEFORE confirmation. Never auto-promoted to Material (I1).
model POLineItem {
  id           String        @id @default(uuid())
  poId         String
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  materialName String
  sku          String? // supplier item/product code (NOT the HSN code, NOT the quantity)
  hsnCode      String? // HSN/SAC tax code from the PO (own column — was wrongly under sku)
  quantity     Int // number of PHYSICAL packages (bags/drums) — one QR each. Not bulk Kg.
  unit         String? // package type (Bag/Drum/Can) or measure unit if truly bulk
  weight       Float? // PO-stated weight per package (e.g. 25 for "25 Kg/Bag"); nullable
  batchNumber  String?
  matchType    MatchType     @default(NONE)

  matchedCatalogueId String?
  matchedCatalogue   MasterCatalogueItem? @relation("MatchedCatalogue", fields: [matchedCatalogueId], references: [id])

  edited    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poId])
}

// ───────────────────────── Materials (one per physical unit) ─────────────────────────

model Material {
  id           String         @id @default(uuid())
  uniqueId     String         @unique // "MC-000001" — sequential, zero-padded (I3, I8)
  poId         String
  po           PurchaseOrder  @relation(fields: [poId], references: [id])
  materialName String
  sku          String?
  hsnCode      String? // HSN/SAC tax code carried from the PO line (Phase 2 reference)
  supplier     String?
  batchNumber  String?
  unit         String?
  weight       Float? // PO-stated weight per package, carried from the PO line
  status       MaterialStatus @default(REGISTERED)

  receivedWeight Float? // single manual receiving weight (Phase 1 — not gross/net/tare)
  weighedById    String?
  weighedBy      User?     @relation("WeighedBy", fields: [weighedById], references: [id])
  weighedAt      DateTime?
  arrivedAt      DateTime?
  scannedAt      DateTime?

  balanceKg Float? // Phase 2 — live remaining stock for this unit. Init = receivedWeight.
  // The measure `balanceKg`/`weight` are denominated in: "kg" or "L". Liquids (solvents)
  // are litres. Additive, defaults to "kg" so every existing unit is unchanged. The
  // column keeps its historical name; only the LABEL varies by this field.
  stockUnit String @default("kg")

  // When this unit's label was FIRST printed (in ANY export format — roll PDF, PNG
  // zip, CSV or single PNG; they all yield the same physical sticker). NULL means
  // never printed, which is the one print that needs no approval.
  labelPrintedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrCode          QrCode?
  transactions    StockTransaction[] // Phase 2 — append-only stock movements for this unit
  reprintRequests LabelReprintRequest[]

  @@index([poId])
  @@index([status])
  @@index([sku])
  @@index([supplier])
}

// ───────────────────────── QR Codes ─────────────────────────

model QrCode {
  id         String   @id @default(uuid())
  materialId String   @unique
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  payload    Json // { uniqueId, materialName, sku, supplier, poNumber, batch, date }
  imageRef   String? // data URL or storage key of the rendered QR PNG
  createdAt  DateTime @default(now())
}

// ───────────────────────── Settings (Claude API key) ─────────────────────────

// Encrypted-at-rest key/value store. Claude key lives here (I2).
model Setting {
  id             String   @id @default(uuid())
  key            String   @unique // e.g. "CLAUDE_API_KEY"
  valueEncrypted String // AES-256-GCM ciphertext (never returned to FE)
  valueMasked    String // e.g. "sk-ant-...x9f2" (safe to return)
  iv             String // base64 IV
  authTag        String // base64 GCM auth tag
  updatedById    String?
  updatedBy      User?    @relation("SettingUpdatedBy", fields: [updatedById], references: [id])
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// ───────────────────────── Audit Log (APPEND-ONLY) ─────────────────────────

// I4: never updated or deleted. Corrections create a NEW row referencing the original.
model AuditLog {
  id         String  @id @default(uuid())
  entityType String // "PurchaseOrder" | "Material" | "Setting" | "User" | ...
  entityId   String
  action     String // "PO_UPLOADED" | "STATUS_CHANGE" | "WEIGHT_ENTERED" | "CORRECTION" ...
  actorId    String?
  actor      User?   @relation("ActorAudit", fields: [actorId], references: [id])
  beforeJson Json?
  afterJson  Json?
  device     String?

  correctionOfId String? // points to the AuditLog row this corrects
  correctionOf   AuditLog?  @relation("Corrections", fields: [correctionOfId], references: [id])
  corrections    AuditLog[] @relation("Corrections")

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ───────────────────────── Phase 2: Production Requests ─────────────────────────

// A request raised by a production head — a HEADER holding many material lines (a full
// batch's worth of materials). Store reviews each line independently; the parent status
// is derived from the mix of line statuses.
model ProductionRequest {
  id            String        @id @default(uuid())
  department    Department // forced to the requester's own department (server-side)
  requestedById String
  requestedBy   User          @relation("RequestedBy", fields: [requestedById], references: [id])
  note          String? // optional batch label / note
  status        RequestStatus @default(PENDING) // DERIVED from the line items
  reviewedById  String? // Store user who last actioned a line
  reviewedBy    User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items ProductionRequestItem[]

  @@index([department])
  @@index([status])
  @@index([requestedById])
}

// One material line within a request. Store accepts / partial-fulfills / rejects each
// line independently; issues (Step 6) link to a line, not the parent.
model ProductionRequestItem {
  id              String            @id @default(uuid())
  requestId       String
  request         ProductionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  materialName    String // picked from the Master Catalogue
  sku             String?
  catalogueItemId String?
  requestedKg     Float
  // The unit of requestedKg/approvedKg/issuedKg on this line: "kg" or "L". Additive,
  // defaults to "kg" so every existing line is unchanged. The *Kg columns keep their
  // names; this labels them.
  unit            String            @default("kg")
  status          RequestStatus     @default(PENDING) // PENDING/APPROVED/PARTIAL/REJECTED
  approvedKg      Float? // = requestedKg (accept) or a lower amount (partial)
  rejectionReason String?
  issuedKg        Float             @default(0) // running total issued via verified scans (Step 6)
  reviewedAt      DateTime?
  fulfilledAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Phase 3 — the batch this material line is for. Per LINE (not per request) because a
  // head may order for several batches at once. Nullable: pre-Phase-3 lines have none.
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  transactions StockTransaction[]

  @@index([requestId])
  @@index([status])
  @@index([batchId])
}

// ───────────────────────── Phase 2: Stock Transactions (APPEND-ONLY) ─────────────────────────

// Immutable ledger — one row per Add/Deduct/Discard on a physical unit. Never
// updated/deleted (extends the I4 audit pattern). Material.balanceKg is updated in
// the SAME DB transaction so the running balance and log never drift.
model StockTransaction {
  id            String                 @id @default(uuid())
  materialId    String // the physical unit that was scanned
  material      Material               @relation(fields: [materialId], references: [id])
  type          StockTxnType
  quantityKg    Float // always > 0
  department    Department? // required for ADD (from) & DEDUCT (for); null for DISCARD
  requestItemId String? // linked request LINE when request-driven (null for standalone scans)
  requestItem   ProductionRequestItem? @relation(fields: [requestItemId], references: [id])
  actorId       String // Store user (the sole scanner/issuer)
  actor         User                   @relation("TxnActor", fields: [actorId], references: [id])
  balanceAfter  Float // unit balance snapshot AFTER this txn (reconcile/audit)
  note          String?
  createdAt     DateTime               @default(now())

  @@index([materialId])
  @@index([type])
  @@index([department])
  @@index([requestItemId])
  @@index([createdAt])
}

// ───────────────────────── Phase 3: Batches, Finished Goods & Dispatch ─────────────────────────

// A production batch — the thread tying raw materials to finished goods. A first-class
// record (not free text) so heads can SELECT an existing batch for top-up requests and
// the FG → material trace can never break on a typo.
model Batch {
  id          String      @id @default(uuid())
  batchNumber String // human code typed by the head, e.g. "B-001"
  department  Department // scoped: a PU head only ever sees PU batches
  status      BatchStatus @default(OPEN)
  note        String?

  createdById String
  createdBy   User   @relation("BatchCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestItems      ProductionRequestItem[] // every line, incl. later top-ups
  productionOutputs ProductionOutput[]
  finishedGoods     FinishedGood[]

  // Unique per department — PU "B-001" and ENAMEL "B-001" may coexist.
  @@unique([department, batchNumber])
  @@index([department, status])
  @@index([createdAt])
}

// What was actually produced from a batch. Recorded by the head, then explicitly
// CONFIRMED (the review gate) — FG QR codes cannot be generated before confirmation.
model ProductionOutput {
  id             String   @id @default(uuid())
  batchId        String
  batch          Batch    @relation(fields: [batchId], references: [id])
  productName    String
  packageCount   Int // number of drums/packages produced → one FG QR each
  sizePerPackage Float // e.g. 20
  sizeUnit       String   @default("L") // "L" or "Kg"
  productionDate DateTime
  shade          String? // colour / shade reference
  productSku     String?
  notes          String?

  // Review gate (mirrors the Phase 1 PO confirm pattern).
  confirmed     Boolean   @default(false)
  confirmedById String?
  confirmedBy   User?     @relation("OutputConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt   DateTime?

  // Set once FG units have been minted, so QRs are never generated twice.
  fgGeneratedAt DateTime?

  recordedById String
  recordedBy   User   @relation("OutputRecordedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  finishedGoods   FinishedGood[]
  reprintRequests LabelReprintRequest[]

  @@index([batchId])
  @@index([confirmed])
}

// ONE row per physical drum/package of finished product — the FG counterpart of
// Material. Its uniqueId uses the FG- prefix so it can never be confused with a raw
// material unit (MC-) in a scan or a report.
model FinishedGood {
  id       String @id @default(uuid())
  uniqueId String @unique // "FG-000001" — sequential, zero-padded

  outputId String
  output   ProductionOutput @relation(fields: [outputId], references: [id])
  batchId  String
  batch    Batch            @relation(fields: [batchId], references: [id])

  productName    String
  sizePerPackage Float
  sizeUnit       String
  status         FgStatus @default(GENERATED)

  dispatchedAt   DateTime?
  dispatchedById String?
  dispatchedBy   User?     @relation("FgDispatchedBy", fields: [dispatchedById], references: [id])
  dispatchNote   String?

  // Returns (additive). A returned unit ends as SCRAPPED, or REFURBISHED — in which
  // case a NEW unit is minted with `refurbishedFrom` pointing back here, and the SAME
  // batch/output, so it traces to its real origin and never looks newly produced.
  returnedAt        DateTime?
  returnNote        String?
  returnedById      String?
  returnedBy        User?         @relation("FgReturnedBy", fields: [returnedById], references: [id])
  refurbishedFromId String?       @unique
  refurbishedFrom   FinishedGood? @relation("FgRefurbLineage", fields: [refurbishedFromId], references: [id])
  refurbishedInto   FinishedGood? @relation("FgRefurbLineage")

  // Set when a correction changed a field printed on the physical label (product
  // name / size); cleared when the unit's label is reprinted.
  qrReprintNeeded Boolean @default(false)

  // When this unit's label was FIRST printed, whether via the output roll or its own
  // single-unit PDF. NULL = never printed; that first print needs no approval.
  labelPrintedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrCode          FinishedGoodQr?
  reprintRequests LabelReprintRequest[]

  @@index([batchId])
  @@index([outputId])
  @@index([status])
}

// FG QR payload/image. Kept separate from QrCode (which is hard-bound to Material), so
// Phase 1's QR pipeline is untouched. Label rendering reuses the same 3×1.5" roll.
model FinishedGoodQr {
  id             String       @id @default(uuid())
  finishedGoodId String       @unique
  finishedGood   FinishedGood @relation(fields: [finishedGoodId], references: [id], onDelete: Cascade)
  payload        Json // { uniqueId, productName, batch, size, department, date }
  imageRef       String? // data URL of the rendered QR PNG
  createdAt      DateTime     @default(now())
}

// ───────────────────── Label reprint approvals (the lock) ─────────────────────

// Which labels one request covers. Exactly one target column is set — enforced by a
// CHECK constraint in the migration, because Prisma cannot express it.
enum LabelScope {
  PO_LABELS // every unit of a purchase order
  MC_UNIT_LABEL // a single raw-material unit (its individual PNG)
  FG_OUTPUT_LABELS // every finished-goods unit of a production output
  FG_UNIT_LABEL // a single finished-goods unit
}

enum ReprintStatus {
  PENDING
  APPROVED
  REJECTED
  CONSUMED // the approved number of prints has been used up
}

/**
 * A request to print labels that have ALREADY been printed once.
 * Minting is untouched by this — a QR is still created exactly once, at registration
 * (MC) or at output confirm (FG). This table gates only the REPRINT: the same stored
 * payload, through the same label renderer, onto more paper.
 * The approval carries a QUOTA. The factory Admin decides how many prints it buys
 * (`printsApproved`); each print increments `printsUsed`, and the request flips to
 * CONSUMED when the quota is spent. So it is a lock, not a workflow: once open, the
 * print behaves exactly as it always has, for as many prints as were granted.
 */
model LabelReprintRequest {
  id    String     @id @default(uuid())
  scope LabelScope

  poId String?
  po   PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: Cascade)

  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: Cascade)

  outputId String?
  output   ProductionOutput? @relation(fields: [outputId], references: [id], onDelete: Cascade)

  finishedGoodId String?
  finishedGood   FinishedGood? @relation(fields: [finishedGoodId], references: [id], onDelete: Cascade)

  reason String // required — why these labels need printing again
  status ReprintStatus @default(PENDING)

  requestedById String
  requestedBy   User     @relation("ReprintRequestedBy", fields: [requestedById], references: [id])
  requestedAt   DateTime @default(now())

  // Set on approval. printsApproved is the Admin's choice, not a fixed 1.
  decidedById    String?
  decidedBy      User?     @relation("ReprintDecidedBy", fields: [decidedById], references: [id])
  decidedAt      DateTime?
  decisionNote   String?
  printsApproved Int       @default(0)
  printsUsed     Int       @default(0)
  lastPrintedAt  DateTime?

  @@index([status])
  @@index([poId])
  @@index([materialId])
  @@index([outputId])
  @@index([finishedGoodId])
}

// ───────────────────── Digital receiving slip (segregation of duties) ─────────────────────

enum SlipStatus {
  DRAFT // born at extraction — Gate is proofreading it against the paper
  AWAITING_STORE // Gate has proofread and handed over; Gate can no longer edit
  FINALIZED // Store finished receiving against it
}

/**
 * What the gate hands to Store — the commercial-free record of one inward.
 * Store no longer sees the invoice, so this is how it learns what arrived: supplier,
 * date, materials, quantities with kg and L kept separate, pack weights and the unit ID
 * ranges. It carries NO price, no amount, no HSN and no invoice image, and `lines` is
 * built by an explicit field-by-field mapper rather than by spreading a record.
 * `lines` is denormalised on purpose. The slip is a record of what was physically handed
 * over, so a later catalogue or material edit must never rewrite what the gate guard
 * already printed and walked across the yard.
 * A DRAFT slip is fully visible and printable: a gate guard forgetting to press Done
 * must never hide an inward from Store.
 */
model ReceivingSlip {
  id         String        @id @default(uuid())
  slipNumber String        @unique // "RS-000001" — its own sequence, reset at handover
  poId       String        @unique
  po         PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  supplier     String?
  receivedDate DateTime

  /// [{ materialName, sku, quantity, unit, packWeight, measure, idFrom, idTo }]
  lines     Json
  /// Null until Store confirms — at extraction no unit exists yet.
  unitCount Int?
  status    SlipStatus @default(DRAFT)

  /// Set when Store confirms and the unit ID ranges attach to the lines.
  confirmedAt DateTime?

  generatedById String
  generatedBy   User     @relation("SlipGeneratedBy", fields: [generatedById], references: [id])
  generatedAt   DateTime @default(now())

  /// When Gate pressed "Looks right — send to Store".
  handedOverAt DateTime?

  finalizedById String?
  finalizedBy   User?     @relation("SlipFinalizedBy", fields: [finalizedById], references: [id])
  finalizedAt   DateTime?
  scannedCount  Int? // how many units the gate actually scanned in, at Done

  @@index([status])
  @@index([receivedDate])
}

// ───────────────────────── Operational flags ─────────────────────────

/**
 * A plain operational switch — NOT a secret, so deliberately not a `Setting` (that model
 * exists for AES-encrypted values like the Claude key and every crypto field on it is
 * required).
 * Today it holds exactly one key, STORE_INWARD_ACCESS, which is what makes the
 * segregation-of-duties cutover reversible in seconds instead of a redeploy: revoking
 * Store's inward access is a value change, and restoring it is the same change back.
 */
model SystemFlag {
  key         String   @id
  value       String
  updatedById String?
  updatedBy   User?    @relation("FlagUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime @updatedAt
}
