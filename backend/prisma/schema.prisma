// Modern Colours — Phase 1 data model.
// Source of truth: docs/ARCHITECTURE.md §6. Update BOTH together on any change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations use a DIRECT (non-pooled) connection — Prisma migrate needs advisory
  // locks that Neon's PgBouncer pooler does not support (they hang). Runtime queries
  // still use the pooled DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Enums ─────────────────────────

enum Role {
  ADMIN // Phase 1 full access; in Phase 2 this login is the "Store" (label only)
  SUPERVISOR
  OPERATOR
  OVERSIGHT // Phase 2 — factory-wide VIEW-ONLY "Admin" (no actions)
  PRODUCTION_HEAD // Phase 2 — PU/Enamel/Powder head, scoped by `department`
}

// Phase 2 — production departments. A PRODUCTION_HEAD is scoped to exactly one.
enum Department {
  PU
  ENAMEL
  POWDER
}

// Phase 2 — request lifecycle. Used per-LINE (PENDING/APPROVED/PARTIAL/REJECTED) and for
// the parent request overall status (adds IN_PROGRESS when some lines are still pending).
enum RequestStatus {
  PENDING // awaiting Store
  IN_PROGRESS // PARENT ONLY — some lines actioned, some still pending
  APPROVED // line: full accept · parent: every line approved
  PARTIAL // line: lower approvedKg · parent: reviewed with a mixed outcome
  REJECTED // line: rejected with a reason · parent: every line rejected
}

// Phase 2 — stock movement type. Every unit scan offers all three (Override 3).
enum StockTxnType {
  ADD // material coming back INTO stock (from a department)
  DEDUCT // material going OUT (for a department)
  DISCARD // wasted/damaged, not tied to a department
}

// PO-level lifecycle (the document). See ARCHITECTURE.md §6 status note.
enum POStatus {
  PO_UPLOADED // uploaded, extraction not yet run
  AI_EXTRACTED // Claude returned fields; pending review
  OPERATOR_VERIFIED // operator confirmed (hard gate passed)
  REGISTERED // materials + QR created
}

// How the PO data was produced.
enum POSource {
  AI // Claude extraction
  MANUAL // manual-entry fallback (I7)
}

// Per-physical-unit lifecycle (the tracked entity after registration).
enum MaterialStatus {
  REGISTERED
  ARRIVED
  SCANNED
  WEIGHED
  READY_FOR_PRODUCTION
}

// Catalogue match outcome for an extracted line (I6 — informational, never gates).
enum MatchType {
  EXACT
  SIMILAR
  NONE
}

// ───────────────────────── Users / Auth ─────────────────────────

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         Role        @default(OPERATOR)
  department   Department? // Phase 2 — set only for PRODUCTION_HEAD users
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  uploadedPOs        PurchaseOrder[]     @relation("UploadedBy")
  confirmedPOs       PurchaseOrder[]     @relation("ConfirmedBy")
  weighedUnits       Material[]          @relation("WeighedBy")
  auditEntries       AuditLog[]          @relation("ActorAudit")
  settingsUpdates    Setting[]           @relation("SettingUpdatedBy")
  productionRequests ProductionRequest[] @relation("RequestedBy")
  reviewedRequests   ProductionRequest[] @relation("ReviewedBy")
  stockTransactions  StockTransaction[]  @relation("TxnActor")

  @@index([role])
}

// ───────────────────────── Master Catalogue ─────────────────────────

model MasterCatalogueItem {
  id                String   @id @default(uuid())
  materialName      String
  sku               String   @unique
  hsnCode           String? // HSN/SAC tax code — distinct from SKU (see FIELD_REFERENCE.md)
  category          String?
  unit              String?
  standardPackaging String?
  metadata          Json?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  matchedLineItems POLineItem[] @relation("MatchedCatalogue")

  @@index([materialName])
  @@index([sku])
}

// ───────────────────────── Purchase Orders ─────────────────────────

model PurchaseOrder {
  id            String    @id @default(uuid())
  poNumber      String?
  supplier      String?
  fileKey       String? // storage key (R2 / disk). Null only for pure manual entry.
  fileName      String?
  status        POStatus  @default(PO_UPLOADED)
  source        POSource  @default(AI)
  extractedJson Json? // raw Claude output for audit/debug
  deliveryDate  DateTime?

  uploadedById String
  uploadedBy   User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  confirmedById String?
  confirmedBy   User?     @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems POLineItem[]
  materials Material[]

  @@index([poNumber])
  @@index([supplier])
  @@index([status])
  @@index([createdAt])
}

// Editable working set BEFORE confirmation. Never auto-promoted to Material (I1).
model POLineItem {
  id           String        @id @default(uuid())
  poId         String
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  materialName String
  sku          String? // supplier item/product code (NOT the HSN code, NOT the quantity)
  hsnCode      String? // HSN/SAC tax code from the PO (own column — was wrongly under sku)
  quantity     Int // number of PHYSICAL packages (bags/drums) — one QR each. Not bulk Kg.
  unit         String? // package type (Bag/Drum/Can) or measure unit if truly bulk
  weight       Float? // PO-stated weight per package (e.g. 25 for "25 Kg/Bag"); nullable
  batchNumber  String?
  matchType    MatchType     @default(NONE)

  matchedCatalogueId String?
  matchedCatalogue   MasterCatalogueItem? @relation("MatchedCatalogue", fields: [matchedCatalogueId], references: [id])

  edited    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poId])
}

// ───────────────────────── Materials (one per physical unit) ─────────────────────────

model Material {
  id           String         @id @default(uuid())
  uniqueId     String         @unique // "MC-000001" — sequential, zero-padded (I3, I8)
  poId         String
  po           PurchaseOrder  @relation(fields: [poId], references: [id])
  materialName String
  sku          String?
  hsnCode      String? // HSN/SAC tax code carried from the PO line (Phase 2 reference)
  supplier     String?
  batchNumber  String?
  unit         String?
  weight       Float? // PO-stated weight per package, carried from the PO line
  status       MaterialStatus @default(REGISTERED)

  receivedWeight Float? // single manual receiving weight (Phase 1 — not gross/net/tare)
  weighedById    String?
  weighedBy      User?     @relation("WeighedBy", fields: [weighedById], references: [id])
  weighedAt      DateTime?
  arrivedAt      DateTime?
  scannedAt      DateTime?

  balanceKg Float? // Phase 2 — live remaining stock (KG) for this unit. Init = receivedWeight.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrCode       QrCode?
  transactions StockTransaction[] // Phase 2 — append-only stock movements for this unit

  @@index([poId])
  @@index([status])
  @@index([sku])
  @@index([supplier])
}

// ───────────────────────── QR Codes ─────────────────────────

model QrCode {
  id         String   @id @default(uuid())
  materialId String   @unique
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  payload    Json // { uniqueId, materialName, sku, supplier, poNumber, batch, date }
  imageRef   String? // data URL or storage key of the rendered QR PNG
  createdAt  DateTime @default(now())
}

// ───────────────────────── Settings (Claude API key) ─────────────────────────

// Encrypted-at-rest key/value store. Claude key lives here (I2).
model Setting {
  id             String   @id @default(uuid())
  key            String   @unique // e.g. "CLAUDE_API_KEY"
  valueEncrypted String // AES-256-GCM ciphertext (never returned to FE)
  valueMasked    String // e.g. "sk-ant-...x9f2" (safe to return)
  iv             String // base64 IV
  authTag        String // base64 GCM auth tag
  updatedById    String?
  updatedBy      User?    @relation("SettingUpdatedBy", fields: [updatedById], references: [id])
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// ───────────────────────── Audit Log (APPEND-ONLY) ─────────────────────────

// I4: never updated or deleted. Corrections create a NEW row referencing the original.
model AuditLog {
  id         String  @id @default(uuid())
  entityType String // "PurchaseOrder" | "Material" | "Setting" | "User" | ...
  entityId   String
  action     String // "PO_UPLOADED" | "STATUS_CHANGE" | "WEIGHT_ENTERED" | "CORRECTION" ...
  actorId    String?
  actor      User?   @relation("ActorAudit", fields: [actorId], references: [id])
  beforeJson Json?
  afterJson  Json?
  device     String?

  correctionOfId String? // points to the AuditLog row this corrects
  correctionOf   AuditLog?  @relation("Corrections", fields: [correctionOfId], references: [id])
  corrections    AuditLog[] @relation("Corrections")

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ───────────────────────── Phase 2: Production Requests ─────────────────────────

// A request raised by a production head — a HEADER holding many material lines (a full
// batch's worth of materials). Store reviews each line independently; the parent status
// is derived from the mix of line statuses.
model ProductionRequest {
  id            String        @id @default(uuid())
  department    Department // forced to the requester's own department (server-side)
  requestedById String
  requestedBy   User          @relation("RequestedBy", fields: [requestedById], references: [id])
  note          String? // optional batch label / note
  status        RequestStatus @default(PENDING) // DERIVED from the line items
  reviewedById  String? // Store user who last actioned a line
  reviewedBy    User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items ProductionRequestItem[]

  @@index([department])
  @@index([status])
  @@index([requestedById])
}

// One material line within a request. Store accepts / partial-fulfills / rejects each
// line independently; issues (Step 6) link to a line, not the parent.
model ProductionRequestItem {
  id              String            @id @default(uuid())
  requestId       String
  request         ProductionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  materialName    String // picked from the Master Catalogue
  sku             String?
  catalogueItemId String?
  requestedKg     Float
  status          RequestStatus     @default(PENDING) // PENDING/APPROVED/PARTIAL/REJECTED
  approvedKg      Float? // = requestedKg (accept) or a lower amount (partial)
  rejectionReason String?
  issuedKg        Float             @default(0) // running total issued via verified scans (Step 6)
  reviewedAt      DateTime?
  fulfilledAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  transactions StockTransaction[]

  @@index([requestId])
  @@index([status])
}

// ───────────────────────── Phase 2: Stock Transactions (APPEND-ONLY) ─────────────────────────

// Immutable ledger — one row per Add/Deduct/Discard on a physical unit. Never
// updated/deleted (extends the I4 audit pattern). Material.balanceKg is updated in
// the SAME DB transaction so the running balance and log never drift.
model StockTransaction {
  id            String                 @id @default(uuid())
  materialId    String // the physical unit that was scanned
  material      Material               @relation(fields: [materialId], references: [id])
  type          StockTxnType
  quantityKg    Float // always > 0
  department    Department? // required for ADD (from) & DEDUCT (for); null for DISCARD
  requestItemId String? // linked request LINE when request-driven (null for standalone scans)
  requestItem   ProductionRequestItem? @relation(fields: [requestItemId], references: [id])
  actorId       String // Store user (the sole scanner/issuer)
  actor         User                   @relation("TxnActor", fields: [actorId], references: [id])
  balanceAfter  Float // unit balance snapshot AFTER this txn (reconcile/audit)
  note          String?
  createdAt     DateTime               @default(now())

  @@index([materialId])
  @@index([type])
  @@index([department])
  @@index([requestItemId])
  @@index([createdAt])
}
